VECTOR_DB=oracle

# Root PDF to ingest.
PDF_PATH=move-oracle-cloud-using-zero-downtime-migration.pdf

# Ollama local APIs.
OLLAMA_BASE_URL=http://localhost:11434
EMBED_MODEL=nomic-embed-text
CHAT_MODEL=llama3.2

# Oracle Autonomous AI DB or existing Oracle DB.
ORACLE_USER=admin
ORACLE_PASSWORD=change-me
ORACLE_DSN=mydb_high
ORACLE_WALLET_LOCATION=C:\path\to\wallet
ORACLE_WALLET_PASSWORD=

# Existing PostgreSQL/pgvector option.
DATABASE_URL=postgresql://user:password@localhost:5432/vectordemo

CHUNK_SIZE=1200
CHUNK_OVERLAP=200
